  @@index([organizationId, createdAt])
  @@map("ai_usage_logs")
}

// ─── Block 9: Effort Planning ────────────────────────────────────────────────

// Role-based effort plan per task (Level 1)
model TaskRoleEffort {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId       String           @map("task_id") @db.Uuid
  roleId       String           @map("role_id") @db.Uuid
  plannedHours Decimal          @map("planned_hours") @db.Decimal(8, 2)
  distribution DistributionRule @default(uniform)
  // For 'manual' rule: [{ weekStart: "YYYY-MM-DD", pct: number }]
  manualDistJson Json?          @map("manual_dist_json")
  note         String?
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  task    Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role    OrgRole          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  periods TaskEffortPeriod[]

  @@unique([taskId, roleId])
  @@index([taskId])
  @@map("task_role_efforts")
}

// Pre-calculated weekly effort breakdown (regenerated when task dates or distribution change)
model TaskEffortPeriod {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleEffortId String   @map("role_effort_id") @db.Uuid
  taskId       String   @map("task_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  weekStart    DateTime @map("week_start") @db.Date
  plannedHours Decimal  @map("planned_hours") @db.Decimal(6, 2)

  roleEffort TaskRoleEffort @relation(fields: [roleEffortId], references: [id], onDelete: Cascade)
  task       Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role       OrgRole        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleEffortId, weekStart])
  @@index([taskId, weekStart])
  @@index([roleId, weekStart])
  @@map("task_effort_periods")
}

// Time log — actual hours per user per task per day (Level 2)
model TimeEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  hours     Decimal  @db.Decimal(5, 2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, date])
  @@index([taskId])
  @@index([userId, date])
  @@map("time_entries")
}

// ─── Block 8: Templates & Normalization ──────────────────────────────────────

// Global normalization parameter catalog (org-level)
model NormParam {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  code           String        // unique code used in formulas, e.g. "pipeline_km"
  name           String
  paramType      NormParamType @map("param_type")
  unit           String?       // e.g. "км", "м²", "этаж"
  possibleValues Json?         @map("possible_values") // for enum type: ["EPC","EPCM","PMC"]
  description    String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("norm_params")
}

model ProjectTemplate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  description    String?
  category       String?
  version        Int      @default(1)
  isPublished    Boolean  @default(false) @map("is_published")
  usageCount     Int      @default(0) @map("usage_count")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?                 @relation("TemplateCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  tasks        TemplateTask[]
  documents    TemplateDocument[]
  usages       ProjectTemplateUsage[]

  @@index([organizationId])
  @@map("project_templates")
}

model TemplateTask {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   String       @map("template_id") @db.Uuid
  parentId     String?      @map("parent_id") @db.Uuid
  title        String
  description  String?
  phase        String?      // phase/stage label e.g. "Проектирование"
  roleName     String?      @map("role_name") // role placeholder (not a FK)
  taskType     TaskType     @default(task) @map("task_type")
  priority     TaskPriority @default(medium)
  baseDuration Decimal      @default(1) @map("base_duration") @db.Decimal(8, 2) // work days
  effortHours  Decimal?     @map("effort_hours") @db.Decimal(8, 2)
  formulaJson  Json?        @map("formula_json") // NormalizationFormula JSON
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz

  template     ProjectTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent       TemplateTask?        @relation("TemplateTaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     TemplateTask[]       @relation("TemplateTaskHierarchy")
  dependencies TemplateDependency[] @relation("TemplateDepTask")
  dependents   TemplateDependency[] @relation("TemplateDepPred")
  documents    TemplateDocument[]
  stat         TemplateTaskStat?

  @@index([templateId])
  @@index([parentId])
  @@map("template_tasks")
}

model TemplateDependency {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId        String         @map("task_id") @db.Uuid
  predecessorId String         @map("predecessor_id") @db.Uuid
  type          DependencyType @default(FS)
  lagDays       Int            @default(0) @map("lag_days")

  task        TemplateTask @relation("TemplateDepTask", fields: [taskId], references: [id], onDelete: Cascade)
  predecessor TemplateTask @relation("TemplateDepPred", fields: [predecessorId], references: [id], onDelete: Cascade)

  @@unique([taskId, predecessorId])
  @@index([taskId])
  @@map("template_dependencies")
}

model TemplateDocument {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String  @map("template_id") @db.Uuid
  taskId      String? @map("task_id") @db.Uuid
  name        String
  description String?
  isRequired  Boolean @default(false) @map("is_required")
  sortOrder   Int     @default(0) @map("sort_order")

  template ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  task     TemplateTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@map("template_documents")
}

model ProjectTemplateUsage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId     String   @map("template_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  scalingParams  Json     @default("{}") @map("scaling_params") // param values used
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  template ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("project_template_usages")
}

// Running statistics per template task (updated when project archived)
model TemplateTaskStat {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateTaskId  String   @unique @map("template_task_id") @db.Uuid
  sampleCount     Int      @default(0) @map("sample_count")
  avgPlanDays     Decimal? @map("avg_plan_days") @db.Decimal(8, 2)
  avgActualDays   Decimal? @map("avg_actual_days") @db.Decimal(8, 2)
  avgDeviationPct Decimal? @map("avg_deviation_pct") @db.Decimal(8, 2)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  templateTask TemplateTask @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)

  @@map("template_task_stats")
}

// ─── Block 7: Analytics & Feedback ───────────────────────────────────────────

model FeatureUsageLog {
