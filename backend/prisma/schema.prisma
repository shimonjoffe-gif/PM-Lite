// ─── Block 9: Documents ───────────────────────────────────────────────────────

model DocumentTypeCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")

  documentTypes DocumentType[]

  @@map("document_type_categories")
}

model DocumentType {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  name           String
  code           String?
  isSystem       Boolean   @default(false) @map("is_system")
  isArchived     Boolean   @default(false) @map("is_archived")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization  Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category      DocumentTypeCategory @relation(fields: [categoryId], references: [id])
  documents     Document[]
  accessRules   DocumentAccessRule[]

  @@index([organizationId])
  @@map("document_types")
}

model Document {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  title          String
  description    String?
  documentTypeId String             @map("document_type_id") @db.Uuid
  parentType     DocumentParentType @map("parent_type")
  parentId       String             @map("parent_id") @db.Uuid
  projectId      String?            @map("project_id") @db.Uuid
  createdBy      String             @map("created_by") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime           @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?          @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator      User         @relation("DocumentCreator", fields: [createdBy], references: [id])
  versions     DocumentVersion[]

  @@index([organizationId])
  @@index([projectId])
  @@index([parentType, parentId])
  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId    String   @map("document_id") @db.Uuid
  versionNumber Int      @map("version_number")
  fileName      String   @map("file_name")
  fileSize      BigInt?  @map("file_size")
  mimeType      String?  @map("mime_type")
  storagePath   String?  @map("storage_path")
  externalId    String?  @map("external_id")
  externalUrl   String?  @map("external_url")
  checksum      String?
  comment       String?
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User             @relation("VersionCreator", fields: [createdBy], references: [id])

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentAccessRule {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  projectId      String?   @map("project_id") @db.Uuid
  documentTypeId String?   @map("document_type_id") @db.Uuid
  orgRoleId      String    @map("org_role_id") @db.Uuid
  canView        Boolean   @default(true) @map("can_view")
  canUpload      Boolean   @default(false) @map("can_upload")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentType DocumentType? @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  orgRole      OrgRole       @relation(fields: [orgRoleId], references: [id], onDelete: Cascade)

  @@index([organizationId, projectId])
  @@map("document_access_rules")
}

model StorageProviderSetting {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String      @unique @map("organization_id") @db.Uuid
  storageMode      StorageMode @default(cloud) @map("storage_mode")
  pluginUrl        String?     @map("plugin_url")
  pluginApiKeyHash String?     @map("plugin_api_key_hash")
  pluginVerifiedAt DateTime?   @map("plugin_verified_at") @db.Timestamptz
  pluginVersion    String?     @map("plugin_version")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("storage_provider_settings")
}
